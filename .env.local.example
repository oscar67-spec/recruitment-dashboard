# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real credentials.

# Airtable Personal Access Token, scoped read-only to your base if possible
AIRTABLE_TOKEN=

# Base ID — found in Airtable's API docs for your base (starts with "app")
AIRTABLE_BASE_ID=

# Table name exactly as it appears in Airtable
AIRTABLE_TABLE_NAME=Candidates
